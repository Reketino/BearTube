{
    "manifest_version": 3,
    "name": "BearTube",
    "version": "0.1.0",
    "description": "Hide Shorts. Keep Uploads",
    "action": {
        "default_popup": "index.html"
    },
    "permissions": ["storage"],
    "host_permissions": [
        "https://www.youtube.com/*"
    ],
    "content_scripts": [
        {
            "matches": [
                "https://www.youtube.com/*"
            ],
            "js": [
                "src/content/index.ts"
            ],
            "run_at": "document_idle"
        }
    ]
}